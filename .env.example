# Environment variables for Andri2 Discord Bot
# Copy this file to .env and fill in your actual tokens

# --- Discord ---
# Get your bot token from: https://discord.com/developers/applications
# NEVER commit this token to git
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# --- GoAgent ---
# URL of the GoAgent server. Defaults to localhost:8080 if not set.
# For local llama.cpp: http://localhost:8080
# For OCI VPS deployment: http://YOUR_VPS_IP:8080
GOAGENT_URL=http://localhost:8080
