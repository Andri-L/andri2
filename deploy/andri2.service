[Unit]
Description=Andri2 Discord Bot
After=network.target

[Service]
Type=simple
User=ubuntu
ExecStart=/usr/bin/node index.js
WorkingDirectory=/home/ubuntu/projects/andri2
Restart=always
RestartSec=3
StartLimitBurst=5
StartLimitIntervalSec=60
EnvironmentFile=/home/ubuntu/projects/andri2/.env

[Install]
WantedBy=multi-user.target
